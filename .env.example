PORT=4000
STRAPI_API_URL=https://your-strapi-instance.strapiapp.com
STRAPI_TOKEN=Bearer your-strapi-api-token
OPENAI_API_KEY=sk-proj-your-openai-key
GEMINI_API_KEY=your-gemini-key
FB_PIXEL_ID=your-fb-pixel-id
FB_ACCESS_TOKEN=your-fb-access-token
GOOGLE_ADS_DEVELOPER_TOKEN=your-google-ads-developer-token
GOOGLE_ADS_CLIENT_ID=your-google-ads-client-id.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=your-google-ads-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-google-ads-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-google-ads-customer-id
TG_TOKEN=your-telegram-bot-token
ADMIN_CHAT_ID=your-admin-chat-id
TG_BOT_ORDERS_ID=your-orders-chat-id
AMAZON_EMAIL=your-amazon-email
AMAZON_PASSWORD=your-amazon-password
TT_TOKEN=your-tiktok-token
FB_FUNNEL_PIXEL_ID=your-fb-funnel-pixel-id
FB_FUNNEL_TOKEN=your-fb-funnel-token

# --- Anti-fraud (funnel) ---
AF_HMAC_SECRET=change-me-long-random
AF_ENFORCE=false
AF_THRESHOLD_CLEAN=70
AF_THRESHOLD_MID=40
AF_THRESHOLD_AD=60
